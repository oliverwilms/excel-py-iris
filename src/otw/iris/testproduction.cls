Class otw.iris.testproduction Extends %UnitTest.TestProduction
{

Parameter PRODUCTION = "otw.iris.production";

Parameter IGNOREPRODUCTIONERRORS = 1;

/// The purpose of this method is to examine errors generated by a production.
/// “error”—specifies the type of Event Log entry to retrieve. Other possible values include: “info”, “infouser”, “trace”, “alert”, and so on.
/// err—passed by reference, this argument contains Event Log information when the method returns.
/// new—passed by reference, this argument contains the number of new Event Log entries.
Method CheckErrors() As %Status
{
 Set tSC = $$$OK
 Set s = ..GetEventLog("error","","",.err,.new)

 Set s1 = $$$AssertEquals(new,3,"Should be 3 new errors(found: "_+$Get(new)_")")

 Set text = $Get(err(1,"Text"))
 Set eText = "Test error case"
 Set s2 = 
     $$$AssertTrue(text[eText,"Should contain '"_eText_"'(found: '"_text_"')")

 if 's1||'s2 set tSC=..Error("Expected error entries don't match")
 Return tSC
}

/// The purpose of the code is to examine the effects of running the production.
/// The Log array contains a node corresponding to each piece of Event Log information including: Text, Type, TimeLogged, SessionId, SourceMethod, and ConfigName.
Method CheckResults(ByRef Log As %String, New As %String) As %Status
{
 Set tSC = $$$OK 
 Set r = $$$AssertEquals($Get(New),2,"Should be 2 (found: "_+$Get(New)_")")

 Set text = $Get(Log(1,"Text"))
 Do $$$AssertEquals(text,"OK","Should be 'OK' (found: '"_text_"')")

 Set text = $Get(Log(2,"Text"))
 Do $$$AssertEquals(text,"ERROR","Should be 'ERROR' (found: '"_text_"')")

 if 'r set tSC=..Error("Expected event log entries don't match")

 Return tSC
}

