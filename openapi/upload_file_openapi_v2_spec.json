{
  "swagger": "2.0",
  "info": {
    "title": "File Upload API",
    "description": "Upload file.",
    "version": "2.0.0"
  },
  "host": "portal.files.com",
  "basePath": "/csp/files",
  "schemes": [
    "https"
  ],
  "consumes": [
    "multipart/form-data"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/upload-file": {
      "post": {
        "tags": [
          "Upload"
        ],
        "summary": "Upload a file",
        "description": "Accepts file via multipart/form-data. Returns a structured JSON response with an ingestion ID on success.",
        "operationId": "uploadFile",
        "consumes": [
          "multipart/form-data"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "file",
            "in": "formData",
            "description": "my data file",
            "required": true,
            "type": "file"
          },
          {
            "name": "metadata",
            "in": "formData",
            "description": "JSON metadata payload containing patient, provider, visit, document, and source information",
            "required": false,
            "type": "string"
          },
          {
            "name": "description",
            "in": "formData",
            "description": "Legacy description field. Use metadata field for structured JSON going forward.",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "File uploaded and stored successfully",
            "schema": {
              "$ref": "#/definitions/UploadSuccessResponse"
            },
            "examples": {
              "application/json": {
                "status": "success",
                "ingestionId": "abc-123",
                "fileName": "sample.pdf",
                "medkazId": "1234",
                "providerNpi": "1234567890",
                "message": "PDF uploaded and stored successfully"
              }
            }
          },
          "400": {
            "description": "Invalid request or invalid metadata",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            },
            "examples": {
              "application/json": {
                "status": "error",
                "code": "INVALID_METADATA",
                "message": "Metadata must be valid JSON",
                "details": [
                  {
                    "field": "metadata",
                    "issue": "Unexpected token at position 12"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            },
            "examples": {
              "application/json": {
                "status": "error",
                "code": "AUTHENTICATION_REQUIRED",
                "message": "Valid Basic Auth credentials are required",
                "details": []
              }
            }
          },
          "409": {
            "description": "Duplicate document",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            },
            "examples": {
              "application/json": {
                "status": "error",
                "code": "DUPLICATE_DOCUMENT",
                "message": "This document was already ingested",
                "details": [
                  {
                    "field": "visit.documentId",
                    "issue": "duplicate",
                    "existingIngestionId": "xyz-789"
                  }
                ]
              }
            }
          },
          "415": {
            "description": "Unsupported media type",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            },
            "examples": {
              "application/json": {
                "status": "error",
                "code": "UNSUPPORTED_FILE_TYPE",
                "message": "Only xlsx files are accepted",
                "details": [
                  {
                    "field": "file",
                    "issue": "expected application/pdf"
                  }
                ]
              }
            }
          },
          "500": {
            "description": "Server error",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            },
            "examples": {
              "application/json": {
                "status": "error",
                "code": "INTERNAL_SERVER_ERROR",
                "message": "An unexpected error occurred while processing the upload",
                "details": []
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    }
  },
  "securityDefinitions": {
    "basicAuth": {
      "type": "basic",
      "description": "HTTP Basic Authentication. Provide username and password for test and integration environments."
    }
  },
  "definitions": {
    "UploadSuccessResponse": {
      "type": "object",
      "required": [
        "status",
        "ingestionId",
        "fileName",
        "medkazId",
        "providerNpi",
        "message"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success"
          ],
          "example": "success"
        },
        "ingestionId": {
          "type": "string",
          "example": "abc-123"
        },
        "fileName": {
          "type": "string",
          "example": "sample.pdf"
        },
        "medkazId": {
          "type": "string",
          "example": "1234"
        },
        "providerNpi": {
          "type": "string",
          "example": "1234567890"
        },
        "message": {
          "type": "string",
          "example": "PDF uploaded and stored successfully"
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "required": [
        "status",
        "code",
        "message",
        "details"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "error"
          ],
          "example": "error"
        },
        "code": {
          "type": "string",
          "example": "INVALID_METADATA"
        },
        "message": {
          "type": "string",
          "example": "Metadata must be valid JSON"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ErrorDetail"
          }
        }
      }
    },
    "ErrorDetail": {
      "type": "object",
      "properties": {
        "field": {
          "type": "string",
          "example": "metadata"
        },
        "issue": {
          "type": "string",
          "example": "required"
        },
        "existingIngestionId": {
          "type": "string",
          "example": "xyz-789"
        },
        "matchType": {
          "type": "string",
          "example": "sha256"
        }
      }
    },
    "MetadataPayload": {
      "type": "object",
      "description": "Structure of the JSON string sent in the metadata form field",
      "required": [
        "patient",
        "provider",
        "visit",
        "source"
      ],
      "properties": {
        "patient": {
          "type": "object",
          "required": [
            "medkazId"
          ],
          "properties": {
            "medkazId": {
              "type": "string",
              "example": "1234"
            },
            "dateOfBirth": {
              "type": "string",
              "format": "date",
              "example": "2000-12-25"
            }
          }
        },
        "provider": {
          "type": "object",
          "required": [
            "npi"
          ],
          "properties": {
            "npi": {
              "type": "string",
              "example": "1234567890"
            }
          }
        },
        "visit": {
          "type": "object",
          "required": [
            "visitDate"
          ],
          "properties": {
            "visitDate": {
              "type": "string",
              "format": "date",
              "example": "2026-06-01"
            },
            "encounterId": {
              "type": "string",
              "example": "optional"
            },
            "documentId": {
              "type": "string",
              "example": "optional"
            },
            "documentType": {
              "type": "string",
              "example": "signed_progress_note"
            }
          }
        },
        "source": {
          "type": "object",
          "required": [
            "ehrVendor",
            "deliveryMethod"
          ],
          "properties": {
            "ehrVendor": {
              "type": "string",
              "example": "athenahealth"
            },
            "deliveryMethod": {
              "type": "string",
              "example": "api_push"
            }
          }
        }
      },
      "example": {
        "patient": {
          "medkazId": "1234",
          "dateOfBirth": "2000-12-25"
        },
        "provider": {
          "npi": "1234567890"
        },
        "visit": {
          "visitDate": "2026-06-01",
          "encounterId": "optional",
          "documentId": "optional",
          "documentType": "signed_progress_note"
        },
        "source": {
          "ehrVendor": "athenahealth",
          "deliveryMethod": "api_push"
        }
      }
    }
  }
}
